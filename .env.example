# ── Save My Tokens ─────────────────────────────
# Copy to .env:  cp .env.example .env
# Or run the wizard:  python connector/setup.py
# ───────────────────────────────────────────────

# Neo4j Aura (free tier at https://console.neo4j.io)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j

# NAMS Agent Memory (https://memory.neo4jlabs.com)
# Create workspace → Settings → API Keys → copy key
# IMPORTANT: set workspace to "external" db mode pointing at your AuraDB above
NAMS_API_KEY=nams_your_key_here
NAMS_WORKSPACE_ID=your-workspace-uuid

# OpenAI (https://platform.openai.com/api-keys)
# Used for embeddings (text-embedding-3-small) + concept tagging (gpt-4o-mini)
OPENAI_API_KEY=sk-your_key_here
